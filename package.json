{
  "name": "project-sentinal",
  "version": "2.0.0",
  "description": "AI-powered security team-in-a-box. Multi-agent security testing platform with AutoGen-style orchestration.",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sentinel": "./dist/cli/index.js"
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/cli/index.ts",
    "cli": "tsx src/cli/index.ts",
    "demo": "tsx src/cli/index.ts demo",
    "start": "tsx src/cli/index.ts",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "security",
    "pentesting",
    "ai-agents",
    "autogen",
    "vulnerability-scanner",
    "azure-ai",
    "red-team",
    "devsecops"
  ],
  "author": "Project Sentinel Team",
  "license": "MIT",
  "dependencies": {
    "@azure/openai": "^2.0.0",
    "@inquirer/prompts": "^8.4.3",
    "@langchain/anthropic": "^1.4.0",
    "@langchain/core": "^1.1.47",
    "@langchain/langgraph": "^1.3.2",
    "@langchain/openai": "^1.4.6",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^12.0.0",
    "deepagents": "^1.10.2",
    "langchain": "^1.4.1",
    "openai": "^4.28.0",
    "playwright": "^1.40.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
